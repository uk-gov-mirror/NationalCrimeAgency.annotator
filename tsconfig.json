{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "./target/types",
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "common/**/*.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "server/**/*.ts",
    "../../typings/**/*"
  ],
  "exclude": [
    "target/**/*",
  ],
  "kbn_references": [
    "@kbn/core",
    "@kbn/security-plugin",
    "@kbn/field-formats-plugin",
    "@kbn/config-schema",
    "@kbn/utility-types"
  ]
}
